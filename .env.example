# YouTube Summarizer Configuration
# Copy this file to .env and adjust values as needed

# Ollama Configuration
# URL for the Ollama server
OLLAMA_URL=http://localhost:11434

# Default model to use for summarization
OLLAMA_MODEL=llama3.2:latest

# Model Context Configuration
# Context window size of your LLM model (tokens)
# Common sizes: llama3.1=128000, qwen2.5=128000, mistral-large=128000, gemma2=8192
CONTEXT_WINDOW=120000

# Processing Configuration
# Chunk size for transcript splitting (tokens)
# Rule of thumb: 25-50% of context window to leave room for prompt + response
# Smaller chunks = more LLM calls but better detail
# Larger chunks = fewer calls but may miss details
CHUNK_SIZE=2048

# Overlap between chunks (tokens) for context continuity
# Higher overlap = better continuity but more redundant processing
# Set to 0 to disable overlap
CHUNK_OVERLAP=200

# Rate limiting delay between YouTube API requests (seconds)
RATE_LIMIT_DELAY=2.0

# Directory Configuration
# Base directory for data storage
DATA_DIR=data

# Directory for markdown summaries
DOCS_DIR=data/docs

# Directory for logs
LOGS_DIR=logs

# Timeout Configuration
# Timeout for Ollama requests (seconds)
OLLAMA_TIMEOUT=300

# Timeout for YouTube API requests (seconds)
YOUTUBE_TIMEOUT=30

# Default Files
# Default video list file name
DEFAULT_VIDEO_LIST=videos.txt